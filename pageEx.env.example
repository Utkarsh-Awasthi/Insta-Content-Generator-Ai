# ===========================================
# REQUIRED API KEYS & CREDENTIALS
# ===========================================
# Get these from the respective service dashboards

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Instagram Basic Display API
# Get from: https://developers.facebook.com/docs/instagram-basic-display-api
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_USER_ID=your_instagram_business_account_id_here

# Unsplash API (for free images)
# Get from: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# ===========================================
# OPTIONAL SETTINGS
# ===========================================
# Posting time in 24-hour format (UK time)
POSTING_TIME=10:00

# Content niche (customize for your page)
CONTENT_NICHE=UK budget hacking and accessible investing

# Default hashtags (modify as needed)
HASHTAGS=#UKBudgetHacking,#PersonalFinance,#Investing,#MoneySaving,#UKFinance,#StockMarketForBeginners